{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BugBountyReportNormalized",
  "type": "object",
  "required": [
    "id",
    "source",
    "url",
    "title",
    "vulnerability_class",
    "asset_context",
    "attack_chain",
    "impact",
    "remediation"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "vulnerability_class": {
      "type": "string"
    },
    "owasp_category": {
      "type": "string"
    },
    "cwe": {
      "type": "string"
    },
    "asset_context": {
      "type": "object",
      "properties": {
        "app_type": {
          "type": "string"
        },
        "auth_model": {
          "type": "string"
        },
        "tech_stack": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entry_point": {
          "type": "string"
        }
      }
    },
    "attack_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "action",
          "evidence"
        ],
        "properties": {
          "step": {
            "type": "integer"
          },
          "action": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mitre": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string"
        },
        "data_exposed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "account_takeover": {
          "type": "boolean"
        }
      }
    },
    "remediation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string"
    },
    "cvss_estimate": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    }
  }
}