#!/usr/bin/expect -f
set timeout 300
spawn npx drizzle-kit generate --name strategic_recs
while {1} {
  expect {
    -re "create column" {
      send "\r"
      exp_continue
    }
    -re "rename column" {
      exp_continue
    }
    -re "all columns conflicts" {
      exp_continue
    }
    -re "Generated SQL migration" {
      puts "\nMigration generated successfully"
    }
    -re "No schema changes" {
      puts "\nNo changes needed"
    }
    eof {
      break
    }
  }
}
wait
