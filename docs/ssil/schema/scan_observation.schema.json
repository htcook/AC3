{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/scan_observation.schema.json",
  "title": "SSIL Scan Observation (Normalized)",
  "type": "object",
  "required": [
    "observation_id",
    "asset",
    "scanner",
    "observation_type",
    "confidence",
    "timestamp",
    "evidence"
  ],
  "properties": {
    "observation_id": {
      "type": "string",
      "description": "Unique ID (UUID or stable hash)"
    },
    "asset": {
      "type": "object",
      "required": [
        "asset_id",
        "host",
        "port"
      ],
      "properties": {
        "asset_id": {
          "type": "string"
        },
        "host": {
          "type": "string",
          "description": "hostname or IP"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "protocol": {
          "type": "string",
          "description": "e.g. http, https, ssh, smtp, tcp"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "scanner": {
      "type": "object",
      "required": [
        "name",
        "version",
        "adapter"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "e.g. nuclei, zgrab2"
        },
        "version": {
          "type": "string"
        },
        "adapter": {
          "type": "string",
          "description": "internal adapter name"
        },
        "mode": {
          "type": "string",
          "enum": [
            "passive",
            "active-low",
            "active-standard",
            "active-aggressive"
          ]
        }
      },
      "additionalProperties": false
    },
    "observation_type": {
      "type": "string",
      "enum": [
        "service_banner",
        "tls",
        "http_headers",
        "dns",
        "vulnerability_finding",
        "misconfiguration",
        "exposure_surface",
        "cloud_fingerprint"
      ],
      "description": "Normalized observation category"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "info"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": "object",
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 2000
        },
        "template_id": {
          "type": "string",
          "description": "For template-driven scanners (e.g. nuclei)"
        },
        "cve": {
          "type": "string"
        },
        "cvss": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "request_fingerprint": {
          "type": "string",
          "description": "Hash of request metadata (not raw payload)"
        },
        "response_fingerprint": {
          "type": "string",
          "description": "Hash of response metadata (not raw body)"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "properties": {
        "scan_run_id": {
          "type": "string"
        },
        "policy_profile": {
          "type": "string"
        },
        "rate_limit_bucket": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
