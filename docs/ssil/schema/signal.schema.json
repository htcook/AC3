{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/signal.schema.json",
  "title": "SSIL Derived Signal",
  "type": "object",
  "required": [
    "signal_id",
    "asset_id",
    "signal_type",
    "category",
    "confidence",
    "timestamp",
    "rationale",
    "source_observations"
  ],
  "properties": {
    "signal_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "signal_type": {
      "type": "string",
      "enum": [
        "vulnerability",
        "exposure",
        "weak_signal",
        "intel",
        "hygiene",
        "misconfiguration"
      ]
    },
    "category": {
      "type": "string",
      "description": "e.g. auth_surface, tls_hygiene, dns_takeover, cve"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "rationale": {
      "type": "string",
      "maxLength": 4000
    },
    "source_observations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "enrichment": {
      "type": "object",
      "properties": {
        "cvss": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "cve": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
