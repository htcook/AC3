# Caldera Dashboard — Production Environment Variables
# Copy to .env and fill in values before deployment
#
# FIPS 140-3 Configuration
# ─────────────────────────────────────────────────────────────
# The OpenSSL FIPS provider is activated via PM2 ecosystem.config.cjs
# using the --enable-fips Node.js flag. No env var needed for that.
# Set OPENSSL_CONF only if using a custom FIPS configuration file.
OPENSSL_CONF=/etc/ssl/fips/openssl-fips.cnf

# Certificate Pinning
# ─────────────────────────────────────────────────────────────
# GoPhish SPKI pin (captured 2026-03-04, expires 2036-02-14)
CERT_PIN_GOPHISH=sha256/AR9f8u5V/V79+uX66CqJJQXzy3RcHsqJmqB+ZpcKq7A=

# Caldera pin — set after enabling HTTPS on Caldera server
# CERT_PIN_CALDERA=sha256/<pin-after-https-enabled>

# Application
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Database
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=mysql://user:password@host:port/database?ssl=true

# Caldera C2 Framework
# ─────────────────────────────────────────────────────────────
# CALDERA_BASE_URL=http://134.199.213.248:8888
# CALDERA_API_KEY=<your-caldera-api-key>
# CALDERA_USERNAME=<your-caldera-username>
# CALDERA_PASSWORD=<your-caldera-password>

# GoPhish Phishing Framework
# ─────────────────────────────────────────────────────────────
# GOPHISH_BASE_URL=https://134.199.213.248:3333
# GOPHISH_API_KEY=<your-gophish-api-key>

# Scan Server (SSH)
# ─────────────────────────────────────────────────────────────
# SCAN_SERVER_HOST=<your-scan-server-ip>
# SCAN_SERVER_USER=<ssh-username>
# SCAN_SERVER_SSH_KEY=<base64-encoded-ssh-private-key>

# ZAP Proxy
# ─────────────────────────────────────────────────────────────
# ZAP_BASE_URL=http://<zap-host>:8080
# ZAP_API_KEY=<your-zap-api-key>
