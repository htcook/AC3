# Caldera HTTPS Reverse Proxy Configuration
# ============================================
# This Caddy config terminates TLS in front of Caldera (HTTP :8888)
# and GoPhish (HTTPS :3333), providing FIPS 140-3 compliant encryption.
#
# Prerequisites:
#   1. SSH into the app server (134.199.213.248)
#   2. Install Caddy: apt install -y caddy
#   3. Copy this file to /etc/caddy/Caddyfile
#   4. Run: systemctl restart caddy
#
# After setup, update CALDERA_BASE_URL to https://caldera.aceofcloud.io
# and GOPHISH_BASE_URL to https://gophish.aceofcloud.io

# Caldera C2 Framework - HTTPS termination
caldera.aceofcloud.io {
    # TLS configuration with FIPS 140-3 approved cipher suites
    tls {
        protocols tls1.2 tls1.3
        ciphers TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256 TLS_CHACHA20_POLY1305_SHA256 TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256 TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
    }

    # Proxy to Caldera HTTP backend
    reverse_proxy localhost:8888 {
        # Health check
        health_uri /api/v2/health
        health_interval 30s
        health_timeout 5s

        # Headers
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output file /var/log/caddy/caldera-access.log
        format json
    }
}

# GoPhish Phishing Platform - HTTPS termination
gophish.aceofcloud.io {
    tls {
        protocols tls1.2 tls1.3
        ciphers TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256 TLS_CHACHA20_POLY1305_SHA256 TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256 TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
    }

    # Proxy to GoPhish HTTPS backend (skip TLS verification for self-signed cert)
    reverse_proxy https://localhost:3333 {
        transport http {
            tls_insecure_skip_verify
        }
        health_uri /api/campaigns/?api_key=placeholder
        health_interval 30s
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output file /var/log/caddy/gophish-access.log
        format json
    }
}
