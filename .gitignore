# Client dist (now in dist/public/)
client/dist/

# Deploy: dist/index.js is the bootstrap (committed to git, small)
# dist/_server.js and dist/public/ are rebuilt during Docker build from .client-assets/
!dist/
!dist/index.js
dist/_server.js
dist/public/
# .client-assets/ is pre-built Vite output needed by build.cjs
!.client-assets/
!.client-assets/**
