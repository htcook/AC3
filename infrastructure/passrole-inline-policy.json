{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPassRoleForAC3ECS",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::808038814732:role/ac3-*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "ecs-tasks.amazonaws.com",
            "codebuild.amazonaws.com"
          ]
        }
      }
    }
  ]
}
