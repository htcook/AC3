# ─────────────────────────────────────────────────────────────────────────────
# AC3 Local MySQL Configuration
# Mirrors: RDS parameter group ac3-dev-mysql80
# ─────────────────────────────────────────────────────────────────────────────

[mysqld]
# Character set (matches RDS)
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# InnoDB tuning
innodb-buffer-pool-size = 512M
innodb-log-buffer-size = 64M
innodb-flush-log-at-trx-commit = 2
innodb-io-capacity = 3000
innodb-io-capacity-max = 6000
innodb-lock-wait-timeout = 30
innodb-print-all-deadlocks = ON

# Connection management
max-connections = 200
wait-timeout = 300
interactive-timeout = 300
net-read-timeout = 60
net-write-timeout = 120

# Slow query logging
slow-query-log = ON
long-query-time = 1
log-queries-not-using-indexes = ON
slow-query-log-file = /var/log/mysql/slow.log

# Performance schema
performance-schema = ON

# Binary logging (for local replication testing)
log-bin-trust-function-creators = ON

# General
sql-mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set = utf8mb4
